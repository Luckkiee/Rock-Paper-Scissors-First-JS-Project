<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link rel="stylesheet" href="Rock_Paper_Scissors.css" />
  </head>
  <body>
    <p>Rock Paper Scissors</p>
    <div class="buttons">
      <button onclick="playerMove('Rock')">Rock</button>
      <button onclick="playerMove('Paper')">Paper</button>
      <button onclick="playerMove('Scissors')">Scissors</button>
      <button onclick="scoreReset()">Reset Score</button>
    </div>

    <p class="js-score"></p>
    <p class="js-result"></p>
    <p class="js-moves"></p>
    <script>
      let score = JSON.parse(localStorage.getItem("score")) || {
        wins: 0,
        losses: 0,
        ties: 0,
      };

      let result = "";
      let computerMove = "";
      let move = "";

      function pickComputerMove() {
        const randomMove = Math.random();
        if (randomMove < 1 / 3) {
          computerMove = "Rock";
        } else if (randomMove < 2 / 3) {
          computerMove = "Paper";
        } else {
          computerMove = "Scissors";
        }
      }

      function updateScore() {
        document.querySelector(".js-score").innerHTML =
          `Computer chose ${computerMove}. ${result}<br>
Wins: ${score.wins}, Losses: ${score.losses}, Ties: ${score.ties}`;
      }

      function playerMove(playerChoice) {
        pickComputerMove();
        move = playerChoice;
        if (computerMove === "Rock") {
          if (move === "Rock") {
            result = "Its a Tie!";
          } else if (move === "Paper") {
            result = "You Win!";
          } else if (move === "Scissors") {
            result = "You Lose!";
          }
        } else if (computerMove === "Paper") {
          if (move === "Rock") {
            result = "You Lose!";
          } else if (move === "Paper") {
            result = "Its a Tie!";
          } else if (move === "Scissors") {
            result = "You Win!";
          }
        } else if (computerMove === "Scissors") {
          if (move === "Rock") {
            result = "You Win!";
          } else if (move === "Paper") {
            result = "You Lose!";
          } else if (move === "Scissors") {
            result = "Its a Tie!";
          }
        }
        if (result === "You Win!") {
          score.wins++;
        } else if (result === "You Lose!") {
          score.losses++;
        } else if (result === "Its a Tie!") {
          score.ties++;
        }

        localStorage.setItem("score", JSON.stringify(score));
        updateScore();
        movesDisplay();
        resultDisplay();
      }

      function scoreReset() {
        score.wins = 0;
        score.losses = 0;
        score.ties = 0;

        localStorage.removeItem("score");
        updateScore();
        document.querySelector(".js-score").innerHTML =
          "Score Reset!<br>Wins: 0, Losses: 0, Ties: 0";
        document.querySelector(".js-result").innerHTML = "";
        document.querySelector(".js-moves").innerHTML = "";
      }

      function resultDisplay() {
        document.querySelector(".js-result").innerHTML = result;
      }

      function movesDisplay() {
        document.querySelector(".js-moves").innerHTML =
          `You (${move}) - (${computerMove}) Computer`;
      }

      updateScore();
    </script>
  </body>
</html>
